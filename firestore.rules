rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownUserDoc(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function hasProfile() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasEmail() {
      return signedIn() && request.auth.token.email is string;
    }

    function authEmail() {
      return request.auth.token.email.lower();
    }

    function hasOwnRegistry(userId) {
      return signedIn() &&
        (exists(/databases/$(database)/documents/studentRegistry/$(userId)) ||
          (hasEmail() &&
            exists(/databases/$(database)/documents/studentRegistry/$(authEmail()))));
    }

    function registryRoleMatches(userId) {
      return request.resource.data.role == 'student' ||
        (exists(/databases/$(database)/documents/studentRegistry/$(userId)) &&
          request.resource.data.role ==
            get(/databases/$(database)/documents/studentRegistry/$(userId)).data.role) ||
        (hasEmail() &&
          exists(/databases/$(database)/documents/studentRegistry/$(authEmail())) &&
          request.resource.data.role ==
            get(/databases/$(database)/documents/studentRegistry/$(authEmail())).data.role);
    }

    function isAdmin() {
      return hasProfile() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isEventAdmin() {
      return hasProfile() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in [
          'event_admin',
          'admin'
        ];
    }

    function isEventReviewer() {
      return hasProfile() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'event_admin';
    }

    match /studentRegistry/{registryId} {
      allow read: if isAdmin() ||
        ownUserDoc(registryId) ||
        (hasEmail() && registryId == authEmail());
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if ownUserDoc(userId) || isAdmin();
      allow create: if ownUserDoc(userId) &&
        hasEmail() &&
        hasOwnRegistry(userId) &&
        request.resource.data.email == authEmail() &&
        registryRoleMatches(userId);
      allow update: if isAdmin() ||
        (ownUserDoc(userId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'fcmTokens',
            'lastTokenUpdatedAt',
            'updatedAt'
          ]));
      allow delete: if isAdmin();
    }

    match /reminders/{reminderId} {
      allow read, update, delete: if signedIn() &&
        resource.data.userId == request.auth.uid;
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid;
    }

    match /timetable/{entryId} {
      allow read: if signedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      // Students may manage their own timetable rows (self-upload / edit);
      // admins may manage any.
      allow create: if isAdmin() ||
        (signedIn() && request.resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin() ||
        (signedIn() && resource.data.userId == request.auth.uid);
    }

    // Personal calendar events the student creates (meetings, study, etc.).
    match /calendarEvents/{eventId} {
      allow read, update, delete: if signedIn() &&
        resource.data.userId == request.auth.uid;
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid;
    }

    // Grades / results the student records for CGPA tracking.
    match /grades/{gradeId} {
      allow read, update, delete: if signedIn() &&
        resource.data.userId == request.auth.uid;
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid;
    }

    // Student feedback: a student submits their own; admins read everything.
    match /feedback/{feedbackId} {
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin() ||
        (signedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // Per-student course preferences (nickname, colour, hidden, last read).
    match /coursePrefs/{prefId} {
      allow read, update, delete: if signedIn() &&
        resource.data.userId == request.auth.uid;
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid;
    }

    match /resources/{resourceId} {
      allow read: if signedIn();
      // Admins manage shared resources; students may manage their own
      // auto-generated / personal course materials (userId == their uid).
      allow create: if isAdmin() ||
        (signedIn() && request.resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin() ||
        (signedIn() && resource.data.userId == request.auth.uid);
    }

    match /locations/{locationId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if signedIn();
      allow create, delete: if isAdmin();
      allow update: if signedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'readBy'
        ]) &&
        resource.data.readBy is list &&
        request.resource.data.readBy is list &&
        request.auth.uid in request.resource.data.readBy &&
        request.resource.data.readBy.hasAll(resource.data.readBy) &&
        request.resource.data.readBy.size() <= resource.data.readBy.size() + 1;
    }

    match /eventProposals/{proposalId} {
      allow read: if signedIn() &&
        (resource.data.submittedBy == request.auth.uid || isEventAdmin());
      allow create: if signedIn() &&
        request.resource.data.submittedBy == request.auth.uid &&
        request.resource.data.status == 'submitted';
      allow update: if isAdmin() ||
        (isEventReviewer() &&
          resource.data.status == 'submitted' &&
          request.resource.data.status in [
            'needs_changes',
            'event_admin_rejected',
            'event_admin_checked'
          ]) ||
        (signedIn() &&
          resource.data.submittedBy == request.auth.uid &&
          resource.data.status == 'needs_changes' &&
          request.resource.data.submittedBy == request.auth.uid &&
          request.resource.data.status == 'submitted');
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
