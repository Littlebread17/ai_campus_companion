rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownUserDoc(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function hasProfile() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasEmail() {
      return signedIn() && request.auth.token.email is string;
    }

    function authEmail() {
      return request.auth.token.email.lower();
    }

    function hasOwnRegistry(userId) {
      return signedIn() &&
        (exists(/databases/$(database)/documents/studentRegistry/$(userId)) ||
          (hasEmail() &&
            exists(/databases/$(database)/documents/studentRegistry/$(authEmail()))));
    }

    function registryRoleMatches(userId) {
      return request.resource.data.role == 'student' ||
        (exists(/databases/$(database)/documents/studentRegistry/$(userId)) &&
          request.resource.data.role ==
            get(/databases/$(database)/documents/studentRegistry/$(userId)).data.role) ||
        (hasEmail() &&
          exists(/databases/$(database)/documents/studentRegistry/$(authEmail())) &&
          request.resource.data.role ==
            get(/databases/$(database)/documents/studentRegistry/$(authEmail())).data.role);
    }

    function verifiedStudentProfile(userId) {
      return ownUserDoc(userId) &&
        hasEmail() &&
        request.auth.token.email_verified == true &&
        authEmail().matches('^i[0-9]{8}@student[.]newinti[.]edu[.]my$') &&
        request.resource.data.email == authEmail() &&
        request.resource.data.studentId is string &&
        request.resource.data.studentId.matches('^I[0-9]{8}$') &&
        authEmail() == request.resource.data.studentId.lower() +
          '@student.newinti.edu.my' &&
        request.resource.data.role == 'student';
    }

    function isAdmin() {
      return hasProfile() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isEventAdmin() {
      return hasProfile() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in [
          'event_admin',
          'admin'
        ];
    }

    function isEventReviewer() {
      return hasProfile() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'event_admin';
    }

    match /studentRegistry/{registryId} {
      // Kept only for legacy accounts and elevated roles. New students use
      // verified self-signup and never need administrator pre-approval.
      allow get: if isAdmin() ||
        (hasEmail() &&
          (registryId == request.auth.uid || registryId == authEmail()));
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    match /pendingProfiles/{userId} {
      allow create: if ownUserDoc(userId) &&
        hasEmail() &&
        request.resource.data.keys().hasOnly([
          'name',
          'email',
          'studentId',
          'programme',
          'intakeYear',
          'createdAt'
        ]) &&
        request.resource.data.email == authEmail() &&
        request.resource.data.studentId is string &&
        request.resource.data.studentId.matches('^I[0-9]{8}$') &&
        authEmail() == request.resource.data.studentId.lower() +
          '@student.newinti.edu.my' &&
        request.resource.data.intakeYear is int &&
        request.resource.data.intakeYear >= request.time.year() - 10 &&
        request.resource.data.intakeYear <= request.time.year();
      allow get, delete: if ownUserDoc(userId) || isAdmin();
      allow list, update: if isAdmin();
    }

    match /users/{userId} {
      allow read: if ownUserDoc(userId) || isAdmin();
      allow create: if verifiedStudentProfile(userId) ||
        (ownUserDoc(userId) &&
          hasEmail() &&
          hasOwnRegistry(userId) &&
          request.resource.data.email == authEmail() &&
          registryRoleMatches(userId));
      allow update: if isAdmin() ||
        (ownUserDoc(userId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'fcmTokens',
            'lastTokenUpdatedAt',
            'updatedAt'
          ]));
      allow delete: if isAdmin();
    }

    match /reminders/{reminderId} {
      allow read, update, delete: if signedIn() &&
        resource.data.userId == request.auth.uid;
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid;
    }

    match /timetable/{entryId} {
      allow read: if signedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      // Students may manage their own timetable rows (self-upload / edit);
      // admins may manage any.
      allow create: if isAdmin() ||
        (signedIn() && request.resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin() ||
        (signedIn() && resource.data.userId == request.auth.uid);
    }

    // Personal calendar events the student creates (meetings, study, etc.).
    match /calendarEvents/{eventId} {
      allow read, update, delete: if signedIn() &&
        resource.data.userId == request.auth.uid;
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid;
    }

    // Grades / results the student records for CGPA tracking.
    match /grades/{gradeId} {
      allow read, update, delete: if signedIn() &&
        resource.data.userId == request.auth.uid;
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid;
    }

    // Chat channels (course / group / dm). A user may read and take part only
    // in channels they are a member of. Course + group channels are open to
    // join (a signed-in user may add themselves to memberIds).
    match /channels/{channelId} {
      function isMember() {
        return signedIn() && request.auth.uid in resource.data.memberIds;
      }
      function joiningSelf() {
        return signedIn() &&
          request.auth.uid in request.resource.data.memberIds;
      }
      allow read: if isMember();
      allow create: if joiningSelf();
      // Members can update (send-preview, rename); non-members can update only
      // to add themselves (self-join).
      allow update: if isMember() || joiningSelf();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        function channelMember() {
          return signedIn() && request.auth.uid in
            get(/databases/$(database)/documents/channels/$(channelId))
              .data.memberIds;
        }
        allow read: if channelMember();
        allow create: if channelMember() &&
          request.resource.data.senderId == request.auth.uid;
        // Members may only toggle reactions; no editing text or deleting.
        allow update: if channelMember() &&
          request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['reactions']);
        allow delete: if false;
      }
    }

    // Student feedback: a student submits their own; admins read everything.
    match /feedback/{feedbackId} {
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin() ||
        (signedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // Shared campus WiFi fingerprints: students use them, admins maintain them.
    match /wifiFingerprints/{sampleId} {
      allow read: if signedIn();
      allow create: if isAdmin() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Shared campus adjacency graph (which places are walkable neighbours),
    // auto-learned from real transitions to stabilise indoor positioning.
    match /spatialAdjacency/{edgeId} {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if isAdmin();
    }

    // Per-student course preferences (nickname, colour, hidden, last read).
    match /coursePrefs/{prefId} {
      allow read, update, delete: if signedIn() &&
        resource.data.userId == request.auth.uid;
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid;
    }

    match /resources/{resourceId} {
      allow read: if signedIn();
      // Admins manage shared resources; students may manage their own
      // auto-generated / personal course materials (userId == their uid).
      allow create: if isAdmin() ||
        (signedIn() && request.resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin() ||
        (signedIn() && resource.data.userId == request.auth.uid);
    }

    match /locations/{locationId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if signedIn();
      allow create, delete: if isAdmin();
      // Admins can edit anything; students may only change the attendees list
      // (RSVP join/leave), not the event's details.
      allow update: if isAdmin() ||
        (signedIn() &&
          request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['attendees']));
    }

    match /notifications/{notificationId} {
      allow read: if signedIn();
      allow create, delete: if isAdmin();
      allow update: if signedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'readBy'
        ]) &&
        resource.data.readBy is list &&
        request.resource.data.readBy is list &&
        request.auth.uid in request.resource.data.readBy &&
        request.resource.data.readBy.hasAll(resource.data.readBy) &&
        request.resource.data.readBy.size() <= resource.data.readBy.size() + 1;
    }

    match /eventProposals/{proposalId} {
      allow read: if signedIn() &&
        (resource.data.submittedBy == request.auth.uid || isEventAdmin());
      allow create: if signedIn() &&
        request.resource.data.submittedBy == request.auth.uid &&
        request.resource.data.status == 'submitted';
      allow update: if isAdmin() ||
        (isEventReviewer() &&
          resource.data.status == 'submitted' &&
          request.resource.data.status in [
            'needs_changes',
            'event_admin_rejected',
            'event_admin_checked'
          ]) ||
        (signedIn() &&
          resource.data.submittedBy == request.auth.uid &&
          resource.data.status == 'needs_changes' &&
          request.resource.data.submittedBy == request.auth.uid &&
          request.resource.data.status == 'submitted');
      allow delete: if isAdmin();
    }

    // Canva agent chat log. Each doc has userId; students see/write only their own.
    match /chatHistory/{entryId} {
      allow read: if signedIn() &&
        resource.data.userId == request.auth.uid;
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
