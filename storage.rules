rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function hasProfile() {
      return signedIn() &&
        firestore.exists(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return hasProfile() &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isEventAdmin() {
      return hasProfile() &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in [
          'event_admin',
          'admin'
        ];
    }

    function isPdfProposal() {
      return request.resource != null &&
        request.resource.size < 10 * 1024 * 1024 &&
        request.resource.contentType == 'application/pdf';
    }

    match /event_proposals/{userId}/{fileName} {
      allow read: if signedIn() &&
        (request.auth.uid == userId || isEventAdmin() || isAdmin());
      allow create, update: if signedIn() &&
        request.auth.uid == userId &&
        isPdfProposal();
      allow delete: if isAdmin();
    }

    // Chat image attachments. Any signed-in user may read (channel membership
    // is enforced by Firestore for the message that references the URL) and
    // upload reasonably-sized images.
    match /chat_media/{channelId}/{fileName} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        request.resource.size < 8 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
      allow delete: if isAdmin();
    }

    // Event posters. Anyone signed in can view; admins or the event's proposer
    // may upload a reasonably-sized image.
    match /event_posters/{fileName} {
      allow read: if signedIn();
      allow create, update: if signedIn() &&
        request.resource.size < 8 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
      allow delete: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
